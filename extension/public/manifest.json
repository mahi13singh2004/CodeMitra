{
    "manifest_version": 3,
    "name": "CodeMitra",
    "description": "AI Coding Interview Assistant",
    "version": "1.0.0",
    "icons": {
        "16": "icon16.png",
        "48": "logo.png",
        "128": "icon128.png"
    },
    "action": {
        "default_popup": "index.html",
        "default_title": "CodeMitra",
        "default_icon": {
            "16": "icon16.png",
            "48": "logo.png",
            "128": "icon128.png"
        }
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://leetcode.com/*",
        "http://localhost:5000/*"
    ],
    "background": {
        "service_worker": "src/background/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://leetcode.com/problems/*"
            ],
            "js": [
                "src/content/content.js"
            ],
            "run_at": "document_end"
        }
    ]
}